{
  "name": "@gaud_erp/paperclip-github-manager",
  "version": "4.0.0",
  "description": "Paperclip plugin for GitHub platform — repo sync, PR review, issue triage, CI/CD monitoring, engineering metrics, standup reports, knowledge graphs, and decision logs",
  "license": "MIT",
  "keywords": [
    "paperclip",
    "paperclip-plugin",
    "github",
    "github-manager",
    "pull-request",
    "code-review",
    "ai-agent",
    "knowledge-graph",
    "repository-sync",
    "webhook",
    "obsidian",
    "devops",
    "automation",
    "issue-tracking"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/gauderp/paperclip-github-manager"
  },
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs --watch",
    "build": "node esbuild.config.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "src/db/migrations",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "paperclip": {
    "manifest": "./dist/manifest.js"
  },
  "dependencies": {
    "@paperclipai/plugin-sdk": "2026.517.0"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/react": "^18.3.0",
    "esbuild": "^0.25.0",
    "react": "^18.3.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
